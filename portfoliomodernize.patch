+/* ── Overlay nav (nav-bar = head-nav on index) ── */
+.nav-bar {
+  width: 100%;
+  height: 0;
+  position: fixed;
+  z-index: 99;
+  top: 0;
+  left: 0;
+  background: transparent;
+  overflow: hidden;
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+  align-items: center;
+  transition:
+    height 0.44s cubic-bezier(0.4, 0, 0.2, 1),
+    background 0.44s ease;
+}
+
+.nav-bar.open {
+  height: 100dvh;
+  background: rgba(255, 255, 255, 0.97);
+}
+
+.nav-bar a {
+  display: block;
+  padding: 12px 40px;
+  font-size: 20px;
+  font-weight: 600;
+  letter-spacing: 0.1em;
+  text-transform: uppercase;
+  color: #1a1a2e;
+  text-decoration: none;
+  opacity: 0;
+  transform: translateY(14px);
+  transition:
+    color 0.32s cubic-bezier(0.4, 0, 0.2, 1),
+    opacity 0.28s ease,
+    transform 0.34s cubic-bezier(0.4, 0, 0.2, 1);
+}
+
+.nav-bar.open a              { opacity: 1; transform: translateY(0); }
+.nav-bar.open a:nth-child(1) { transition-delay: 0.06s; }
+.nav-bar.open a:nth-child(2) { transition-delay: 0.12s; }
+.nav-bar.open a:nth-child(3) { transition-delay: 0.18s; }
+.nav-bar.open a:nth-child(4) { transition-delay: 0.24s; }
+
+.nav-bar a:hover {
+  color: #b83b6b;
 }
 
